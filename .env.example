# Core AI settings
AI_PROVIDER="openai-compatible"
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-5.4"
AI_FALLBACK_MODELS="gpt-5.5"
AI_REASONING_EFFORT="medium"

# Optional market data provider for non-A-share daily candles
TWELVE_DATA_API_KEY=""

# Optional runtime overrides
PYTHON_EXECUTABLE="python"
INSIGHT_DB_PATH=""

# Optional proxy settings
HTTPS_PROXY=""
HTTP_PROXY=""
NO_PROXY=""

# Public Supabase / onchain worker
SUPABASE_DB_URL=""
PUBLIC_ONCHAIN_ENABLED="true"
PUBLIC_ONCHAIN_FETCH_TIMES="04:20,10:20,16:20,22:20"
PUBLIC_ONCHAIN_MIN_VALUE_USD="200"
PUBLIC_ONCHAIN_EXCLUDE_RISK_TOKEN="true"
OKX_API_KEY=""
OKX_SECRET_KEY=""
OKX_PASSPHRASE=""
